generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String
  department String  // BCA, BA, BCOM, BBA
  phoneNo   String?
  role      Role     @default(TEACHER)
  
  // Teacher Specific
  isApproved Boolean @default(false)
  
  // Student Specific
  rollNo    String?  @unique
  className String?
  division  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AcademicClass {
  id        String   @id @default(uuid())
  name      String // e.g., "TYBCA"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students Student[]
  courses  Course[]
}

model Student {
  id              String        @id @default(uuid())
  rollNo          String        @unique
  name            String
  academicClassId String
  academicClass   AcademicClass @relation(fields: [academicClassId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  marks             Mark[]
  courseExitSurveys CourseExitSurvey[]
}

model Course {
  id               String        @id @default(uuid())
  code             String        @unique // e.g., "CS401"
  name             String
  category         String        @default("Major")
  department       String        @default("BCA")
  semester         Int           @default(1)
  theoryCredits    Int
  practicalCredits Int
  academicClassId  String
  academicClass    AcademicClass @relation(fields: [academicClassId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  courseOutcomes    CourseOutcome[]
  exams             Exam[]
  courseExitSurveys CourseExitSurvey[]
}

model CourseOutcome {
  id          String   @id @default(uuid())
  coNumber    String // e.g., "CO1"
  description String
  targetPct   Float // Target threshold e.g., 75.0
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions         Question[]
  coPoMappings      CO_PO_Mapping[]
  coPsoMappings     CO_PSO_Mapping[]
  courseExitSurveys CourseExitSurvey[]

  @@unique([courseId, coNumber])
}

model Exam {
  id         String   @id @default(uuid())
  name       String // e.g., "ISA-1", "End-Semester"
  totalMarks Int
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  questions Question[]
}

model Question {
  id       String @id @default(uuid())
  qNumber  String // e.g., "Q1" or "a"
  maxMarks Float? // Null for Main Qs
  examId   String
  exam     Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  parentQuestionId String?
  parentQuestion   Question?  @relation("SubQuestions", fields: [parentQuestionId], references: [id], onDelete: Cascade)
  subQuestions     Question[] @relation("SubQuestions")

  courseOutcomeId String? // Null for Main Qs
  courseOutcome   CourseOutcome? @relation(fields: [courseOutcomeId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  marks Mark[]
}

model Mark {
  id            String   @id @default(uuid())
  obtainedMarks Float
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  questionId    String
  question      Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, questionId])
}

model ProgramOutcome {
  id          String   @id @default(uuid())
  code        String   @unique // e.g., "PO1"
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coPoMappings CO_PO_Mapping[]
}

model ProgramSpecificOutcome {
  id          String   @id @default(uuid())
  code        String   @unique // e.g., "PSO1"
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coPsoMappings CO_PSO_Mapping[]
}

model CO_PO_Mapping {
  id               String         @id @default(uuid())
  correlationLevel Int // 1 (Low), 2 (Medium), 3 (High)
  courseOutcomeId  String
  courseOutcome    CourseOutcome  @relation(fields: [courseOutcomeId], references: [id], onDelete: Cascade)
  programOutcomeId String
  programOutcome   ProgramOutcome @relation(fields: [programOutcomeId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([courseOutcomeId, programOutcomeId])
}

model CO_PSO_Mapping {
  id                       String                 @id @default(uuid())
  correlationLevel         Int                    // 1 (Low), 2 (Medium), 3 (High)
  courseOutcomeId          String
  courseOutcome            CourseOutcome          @relation(fields: [courseOutcomeId], references: [id], onDelete: Cascade)
  programSpecificOutcomeId String
  programSpecificOutcome   ProgramSpecificOutcome @relation(fields: [programSpecificOutcomeId], references: [id], onDelete: Cascade)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  @@unique([courseOutcomeId, programSpecificOutcomeId])
}

model CourseExitSurvey {
  id              String        @id @default(uuid())
  rating          Int // 1-3 rating by the student
  studentId       String
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseOutcomeId String
  courseOutcome   CourseOutcome @relation(fields: [courseOutcomeId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([studentId, courseOutcomeId])
}
